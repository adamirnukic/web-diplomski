{
  "name": "online-game-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"next dev\" \"npm:dev:api\"",
    "dev:web": "next dev",
    "dev:api": "cross-env NODE_OPTIONS=--experimental-sqlite tsx watch server/index.ts",
    "build": "next build",
    "build:api": "tsc -p tsconfig.server.json",
    "start": "next start",
    "start:api": "cross-env NODE_OPTIONS=--experimental-sqlite node dist-server/server/index.js",
    "lint": "next lint",
    "typecheck": "tsc -p tsconfig.server.json --noEmit",
    "test": "tsx shared/games/tic-tac-toe/engine.test.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "4.1.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "nodemailer": "^9.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "2.15.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swr": "^2.3.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^10.4.0",
    "postcss": "^8.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
